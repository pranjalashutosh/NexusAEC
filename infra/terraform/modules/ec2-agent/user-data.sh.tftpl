#!/bin/bash
# ──────────────────────────────────────────────────────────────────────────────
# EC2 user-data for the LiveKit voice agent.
#
# Runs once at first boot. Idempotent on re-runs (bootstrap script with
# user_data_replace_on_change=true means the instance is replaced on changes).
#
# What it does:
#   1. Install Docker + jq + AWS CLI (Amazon Linux 2023 has CLI v2 built in).
#   2. Fetch the agent secret from Secrets Manager → /etc/nexus/.env.
#   3. Log into ECR.
#   4. Pull the agent image (with retries — handles "image not pushed yet").
#   5. Run as a docker container with awslogs log driver → CloudWatch Logs.
#
# Logs from this script go to /var/log/cloud-init-output.log on the instance.
# ──────────────────────────────────────────────────────────────────────────────
set -euxo pipefail

REGION="${aws_region}"
SECRET_NAME="${secret_name}"
ECR_REGISTRY="${ecr_registry}"
ECR_REPO="${ecr_repository}"
IMAGE_TAG="${image_tag}"
LOG_GROUP="${log_group_name}"

# ── 1. Install dependencies ───────────────────────────────────────────────────
dnf update -y
dnf install -y docker jq

systemctl enable --now docker
usermod -aG docker ec2-user

# ── 2. Fetch secrets → /etc/nexus/.env ────────────────────────────────────────
mkdir -p /etc/nexus
chmod 700 /etc/nexus

aws secretsmanager get-secret-value \
  --secret-id "$SECRET_NAME" \
  --region "$REGION" \
  --query SecretString \
  --output text \
  | jq -r 'to_entries[] | "\(.key)=\(.value)"' \
  > /etc/nexus/.env

chmod 600 /etc/nexus/.env

# Add NODE_ENV (not in Secrets Manager — it's not a secret)
echo "NODE_ENV=production" >> /etc/nexus/.env
echo "AWS_REGION=$REGION"  >> /etc/nexus/.env

# ── 3. ECR login ──────────────────────────────────────────────────────────────
aws ecr get-login-password --region "$REGION" \
  | docker login --username AWS --password-stdin "$ECR_REGISTRY"

# ── 4. Pull image (retry up to ~2 minutes — handles image-not-pushed-yet) ────
IMAGE="$ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG"
for i in $(seq 1 12); do
  if docker pull "$IMAGE"; then
    echo "✓ Pulled $IMAGE"
    break
  fi
  echo "Image $IMAGE not yet available (attempt $i/12), retrying in 10s..."
  sleep 10
done

# ── 5. Run the container ──────────────────────────────────────────────────────
# Stop any previous container (idempotent re-runs)
docker rm -f nexus-agent 2>/dev/null || true

docker run -d \
  --name nexus-agent \
  --restart unless-stopped \
  --env-file /etc/nexus/.env \
  --log-driver=awslogs \
  --log-opt awslogs-region="$REGION" \
  --log-opt awslogs-group="$LOG_GROUP" \
  --log-opt awslogs-stream=container \
  --log-opt awslogs-create-group=false \
  "$IMAGE"

echo "✓ nexus-agent running. Tail logs: aws logs tail $LOG_GROUP --follow --region $REGION"
