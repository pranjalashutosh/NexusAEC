{
  "name": "@nexus-aec/agent-graph",
  "version": "0.1.0",
  "private": true,
  "description": "LangGraph graphs (inbox sorting + ReAct worker), state schemas, Redis checkpointer, and job bus for NexusAEC",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint": "^1.1.3",
    "@langchain/openai": "^1.5.3",
    "@nexus-aec/email-providers": "workspace:*",
    "@nexus-aec/intelligence": "workspace:*",
    "@nexus-aec/logger": "workspace:*",
    "@nexus-aec/shared-types": "workspace:*",
    "ioredis": "^5.9.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ioredis-mock": "^8.2.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
